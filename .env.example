# ============================================================
# .env.example — คัดลอกเป็น .env แล้วใส่ค่าจริง (ห้าม commit .env)
#   cp .env.example .env
# ============================================================

# ===== LLM (เลือกอย่างใดอย่างหนึ่ง) =====
# --- แบบ OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# โมเดลแนะนำ (ก.ค. 2026): default = gpt-5.4-mini (tool-calling แม่น + คุ้มค่า)
#   gpt-5.4-mini  $0.75/$4.50  — แนะนำหลัก (production): OpenAI จัดกลุ่ม "tool invocation"
#   gpt-5.4       $2.50/$15    — คุณภาพสูงสุด เหมาะรอบ audit ที่ reasoning ตัวเลขต้องเป๊ะ
#   gpt-5-mini    $0.25/$2.00  — ประหยัด/ห้องอบรม/รัน DAG ทุกวัน
# (หมายเหตุ: gpt-4o-mini ถูกจัดเป็น legacy แล้ว — tool-calling ด้อยกว่า gpt-5 มาก)
OPENAI_MODEL=gpt-5.4-mini

# --- แบบ Azure OpenAI (แนะนำสำหรับข้อมูลราชการจริง — data residency / PDPA) ---
# เหตุผล: OpenAI API โดยตรงส่งข้อมูลออกนอกประเทศ และยังไม่มี region ในไทย
# เมื่อขึ้นข้อมูลงบประมาณจริง ควรใช้ Azure OpenAI เพื่อคุม tenancy/สัญญา/region
# ถ้าตั้ง AZURE_OPENAI_ENDPOINT โค้ด build_llm() จะสลับไปใช้ Azure อัตโนมัติ
# AZURE_OPENAI_API_KEY=xxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini      # ชื่อ deployment ที่สร้างใน Azure portal (ไม่ใช่ชื่อโมเดล)
# OPENAI_API_VERSION=2024-10-21             # ตรวจ API version ล่าสุดที่ Azure รองรับ

# ===== PostgreSQL =====
# หมายเหตุเรื่อง host:
#   - รันด้วย docker compose : compose จะ override DSN ให้ host = "postgres" อยู่แล้ว
#     (ตั้งใน docker-compose.yml) ไม่ต้องแก้ที่นี่
#   - รันสคริปต์ตรง ๆ บนเครื่อง host (ไม่ผ่าน compose) : ใช้ host = localhost ตามด้านล่าง

# ใช้สำหรับ seed (สิทธิ์เต็ม)
PG_ADMIN_DSN=postgresql://cgd_admin:cgd_pass_2026@localhost:5432/cgd_fiscal

# ใช้สำหรับ agent (read-only) — role นี้ถูกสร้างในขั้นตอน seed (seed.sql)
PG_READONLY_DSN=postgresql://cgd_readonly:readonly_pass_2026@localhost:5432/cgd_fiscal

# ===== การส่งรายงานจาก Airflow DAG (task send_report) =====
# เลือกช่องทาง: email | ticket | dry_run  (ค่าเริ่มต้น dry_run = แสดงรายงานใน log เฉย ๆ เหมาะกับห้องอบรม)
REPORT_CHANNEL=dry_run

# --- email (SMTP) : ใช้เมื่อ REPORT_CHANNEL=email ---
# SMTP_HOST=smtp.your-domain.go.th
# SMTP_PORT=587
# SMTP_USER=alerts@your-domain.go.th
# SMTP_PASSWORD=xxxxxxxx
# REPORT_EMAIL_FROM=alerts@your-domain.go.th
# REPORT_EMAIL_TO=auditor1@your-domain.go.th,auditor2@your-domain.go.th

# --- ticket (HTTP webhook เช่น Jira/ServiceNow/Teams) : ใช้เมื่อ REPORT_CHANNEL=ticket ---
# TICKET_WEBHOOK_URL=https://your-ticket-system/api/v1/issues
# TICKET_AUTH_HEADER=Bearer xxxxxxxx

# ===== Linux / Ubuntu (สำหรับ Airflow container permission) =====
# ตั้งเป็นผลของคำสั่ง  id -u  (ปกติ 1000 บน Ubuntu desktop/server)
# เพื่อให้ไฟล์ที่ Airflow สร้าง (logs / audit_trail.log) มี owner ตรงกับผู้ใช้ host
AIRFLOW_UID=1000

# ===== Production setup (เฉพาะ docker-compose.prod.yml) =====
# Fernet key — ใช้เข้ารหัส connection/variable ใน Airflow metadata DB (ห้ามใช้ค่าว่าง)
# สร้างด้วย:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# (install_ubuntu.sh จะ generate ให้อัตโนมัติถ้ายังว่าง)
AIRFLOW_FERNET_KEY=

# admin user ของ Airflow web UI (เปลี่ยนรหัสก่อนใช้จริง)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=ChangeMe_2026
AIRFLOW_ADMIN_EMAIL=admin@cgd.local

# รหัสผ่าน Postgres metadata ของ Airflow (แยกจาก DB ของ lab)
AIRFLOW_DB_PASSWORD=airflow_meta_2026
